{
  "mode": "orchestrated",
  "intention": "Conduct an honest, multi-perspective review of the artifacts under scope/. Surface what is strong, what is weak, and what is uncertain — with calibrated confidence. Each reviewer reads only the artifact assigned to them; cross-cutting synthesis is a separate later pass.",
  "circuit_breakers": {
    "timeout_seconds": 120,
    "conflict_detection": true,
    "resource_multiplier": 2.0,
    "confidence_floor": 0.3,
    "repetition_threshold": 3
  },
  "balance": {
    "track_tokens_per_participant": true,
    "track_cost_per_participant": true,
    "surface_imbalance_at_multiplier": 1.5
  },
  "role_rotation": {
    "max_entries_per_holder": 20,
    "max_seconds_per_holder": 3600
  },
  "convergence": {
    "default_protocol": "escalate_to_repair",
    "arbiter": "human-lead"
  },
  "foundations_loaded_by_default": [
    "fnd-preamble.md",
    "fnd-ledger.md",
    "fnd-participants.md"
  ]
}
