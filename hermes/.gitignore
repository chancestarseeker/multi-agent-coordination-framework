# The ledger is the runtime state, not source. It's created on first append
# and grows as the coordination runs. Version-tracking it would conflict with
# Recursion (the ledger is append-only and survives across sessions; git
# would couple ledger growth to commit cadence).
ledger.jsonl

# Pending signals are transient transport state, not durable truth.
signal/inbox/

# Standard Python and editor noise
.venv/
venv/
__pycache__/
*.pyc
.env
.DS_Store
